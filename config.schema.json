{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/OmarMokhtar-Saad/claudekit/config.schema.json",
  "title": "ClaudeKit Configuration",
  "description": "Configuration schema for .claude/hooks/config.json",
  "type": "object",
  "properties": {
    "hooks": {
      "type": "object",
      "properties": {
        "pre-commit": {
          "type": "object",
          "properties": {
            "command": { "type": "string" },
            "enabled": { "type": "boolean", "default": true },
            "timeout": { "type": "integer", "minimum": 1000, "maximum": 600000, "default": 30000 },
            "blocking": { "type": "boolean", "default": true }
          }
        },
        "post-implement": {
          "type": "object",
          "properties": {
            "command": { "type": "string" },
            "enabled": { "type": "boolean", "default": true },
            "timeout": { "type": "integer", "minimum": 1000, "maximum": 600000, "default": 120000 },
            "blocking": { "type": "boolean", "default": false }
          }
        },
        "pre-plan": {
          "type": "object",
          "properties": {
            "command": { "type": "string" },
            "enabled": { "type": "boolean", "default": true },
            "timeout": { "type": "integer", "minimum": 1000, "maximum": 600000, "default": 5000 },
            "blocking": { "type": "boolean", "default": false }
          }
        },
        "pre-push": {
          "type": "object",
          "properties": {
            "command": { "type": "string" },
            "enabled": { "type": "boolean", "default": true },
            "timeout": { "type": "integer", "minimum": 1000, "maximum": 600000, "default": 300000 },
            "blocking": { "type": "boolean", "default": true }
          }
        },
        "post-tool-use": {
          "type": "object",
          "properties": {
            "command": { "type": "string" },
            "enabled": { "type": "boolean", "default": true },
            "timeout": { "type": "integer", "minimum": 1000, "maximum": 600000, "default": 5000 },
            "blocking": { "type": "boolean", "default": false }
          }
        },
        "file-guard": {
          "type": "object",
          "description": "Blocks access to sensitive files matching 195+ patterns (secrets, credentials, keys, certificates)",
          "properties": {
            "command": { "type": "string", "description": "Command to run for file-guard check" },
            "enabled": { "type": "boolean", "default": true },
            "timeout": { "type": "integer", "minimum": 1000, "maximum": 600000, "default": 5000 },
            "blocking": { "type": "boolean", "default": true },
            "description": { "type": "string", "default": "Blocks access to sensitive files matching 195+ patterns" }
          }
        },
        "check-comment-replacement": {
          "type": "object",
          "description": "Detects when code comments are replaced with implementation stubs or placeholders",
          "properties": {
            "command": { "type": "string", "description": "Command to run for comment replacement check" },
            "enabled": { "type": "boolean", "default": true },
            "timeout": { "type": "integer", "minimum": 1000, "maximum": 600000, "default": 10000 },
            "blocking": { "type": "boolean", "default": true },
            "description": { "type": "string", "default": "Detects when code comments are replaced with implementation stubs" }
          }
        },
        "prompt-injection-scanner": {
          "type": "object",
          "description": "Scans for prompt injection patterns in files and inputs",
          "properties": {
            "command": { "type": "string", "description": "Command to run for prompt injection scanning" },
            "enabled": { "type": "boolean", "default": true },
            "timeout": { "type": "integer", "minimum": 1000, "maximum": 600000, "default": 10000 },
            "blocking": { "type": "boolean", "default": true },
            "description": { "type": "string", "default": "Scans for prompt injection patterns in files and inputs" }
          }
        },
        "auto-checkpoint": {
          "type": "object",
          "description": "Automatically creates checkpoints before significant operations",
          "properties": {
            "command": { "type": "string", "description": "Command to run for auto-checkpoint" },
            "enabled": { "type": "boolean", "default": true },
            "timeout": { "type": "integer", "minimum": 1000, "maximum": 600000, "default": 15000 },
            "blocking": { "type": "boolean", "default": false },
            "description": { "type": "string", "default": "Automatically creates checkpoints before significant operations" }
          }
        }
      }
    },
    "global": {
      "type": "object",
      "properties": {
        "disabled": { "type": "boolean", "default": false },
        "logLevel": { "type": "string", "enum": ["debug", "info", "warn", "error"], "default": "info" },
        "logFile": { "type": "string", "default": ".claude/hooks/hooks.log" },
        "maxConcurrentHooks": { "type": "integer", "minimum": 1, "maximum": 10, "default": 3 }
      }
    },
    "project": {
      "type": "object",
      "properties": {
        "build_cmd": { "type": "string", "description": "Build command (e.g., npm run build)" },
        "test_cmd": { "type": "string", "description": "Test command (e.g., pytest)" },
        "lint_cmd": { "type": "string", "description": "Lint command (e.g., eslint .)" },
        "coverage_cmd": { "type": "string", "description": "Coverage command (e.g., pytest --cov)" }
      }
    },
    "security": {
      "type": "object",
      "properties": {
        "safeMode": { "type": "boolean", "default": true, "description": "Restrict hook commands to allowlist" },
        "allowedCommands": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Additional allowed commands beyond defaults"
        },
        "blockedCommands": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Additional blocked commands"
        },
        "timeout": { "type": "integer", "minimum": 1000, "maximum": 600000, "default": 30000 }
      }
    }
  },
  "additionalProperties": false
}
