BUILD_CMD="dotnet build"
TEST_CMD="dotnet test"
LINT_CMD="dotnet format --verify-no-changes"
COVERAGE_CMD="dotnet test --collect:\"XPlat Code Coverage\" --results-directory ./coverage"
FRAMEWORK="ASP.NET Core/Blazor"
BUILD_SYSTEM="dotnet CLI / MSBuild"
TEST_FRAMEWORK="xUnit"
EXAMPLE_FILE="src/Api/Program.cs"
