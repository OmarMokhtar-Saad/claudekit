BUILD_CMD="composer install"
TEST_CMD="./vendor/bin/phpunit"
LINT_CMD="./vendor/bin/phpstan analyse && ./vendor/bin/php-cs-fixer fix --dry-run"
COVERAGE_CMD="XDEBUG_MODE=coverage ./vendor/bin/phpunit --coverage-html coverage/"
FRAMEWORK="Laravel/Symfony"
BUILD_SYSTEM="Composer"
TEST_FRAMEWORK="PHPUnit + PHPStan"
EXAMPLE_FILE="app/Http/Controllers/Controller.php"
