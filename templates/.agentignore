# =============================================================================
# .agentignore
# Gitignore-style file listing sensitive files and directories that AI agents
# should not access. Used by file-guard and other security hooks.
# =============================================================================

# ---------------------------------------------------------------------------
# Env files
# ---------------------------------------------------------------------------
.env
.env.*
.envrc
*.env

# ---------------------------------------------------------------------------
# SSH keys and configuration
# ---------------------------------------------------------------------------
.ssh/
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
id_ecdsa
id_ecdsa.pub
known_hosts
authorized_keys

# ---------------------------------------------------------------------------
# Cloud provider configs
# ---------------------------------------------------------------------------
.aws/credentials
.aws/config
.gcloud/
.azure/
terraform.tfstate
terraform.tfstate.backup
terraform.tfvars

# ---------------------------------------------------------------------------
# Credential files
# ---------------------------------------------------------------------------
credentials.json
service-account*.json
.netrc
.npmrc
.pypirc
.docker/config.json

# ---------------------------------------------------------------------------
# API tokens and secrets
# ---------------------------------------------------------------------------
.token
.secret
secrets.json
api_key*
*.secret
secrets/

# ---------------------------------------------------------------------------
# Database files
# ---------------------------------------------------------------------------
*.sqlite
*.sqlite3
.pgpass
my.cnf
database.yml

# ---------------------------------------------------------------------------
# Certificates and private keys
# ---------------------------------------------------------------------------
*.cert
*.crt
*.pem
*.key
*.p12
*.pfx
*.jks

# ---------------------------------------------------------------------------
# Password files
# ---------------------------------------------------------------------------
passwd
shadow
.htpasswd
password*
*.passwords

# ---------------------------------------------------------------------------
# Production data
# ---------------------------------------------------------------------------
production/*data*
customer*data*
pii/
*.dump
*.sql.gz

# ---------------------------------------------------------------------------
# CI/CD secrets
# ---------------------------------------------------------------------------
.github/secrets*
vault-secrets*
.gitlab-ci-secrets*
.circleci/secrets*

# ---------------------------------------------------------------------------
# Kubernetes secrets
# ---------------------------------------------------------------------------
k8s/*secret*
kubernetes/*secret*
*-secret.yaml
*-secret.yml

# ---------------------------------------------------------------------------
# Crypto wallets
# ---------------------------------------------------------------------------
wallet.dat
*.wallet
keystore.json

# ---------------------------------------------------------------------------
# Sensitive backups
# ---------------------------------------------------------------------------
secrets/*.bak
credentials/*.backup
*.key.bak
*.pem.bak
