{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Operations Config Schema (v2.0)",
  "description": "Supports file create, delete, and code edit operations with dual format compatibility",
  "type": "object",
  "oneOf": [
    {
      "description": "LEGACY FORMAT - Code edits only (backward compatible)",
      "additionalProperties": false,
      "required": ["plan", "files"],
      "properties": {
        "plan": {
          "type": "string",
          "description": "Plan name (kebab-case)",
          "minLength": 1
        },
        "files": {
          "type": "array",
          "description": "Array of file operations (code edits only)",
          "minItems": 1,
          "maxItems": 5,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "edits"],
            "properties": {
              "path": {
                "type": "string",
                "description": "Relative or absolute path to target file",
                "minLength": 1
              },
              "edits": {
                "type": "array",
                "description": "Array of edit operations",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["find"],
                  "properties": {
                    "find": {
                      "type": "string",
                      "description": "Exact pattern to find in file",
                      "minLength": 1
                    },
                    "add_after": {
                      "type": "string",
                      "description": "Content to add after found pattern"
                    },
                    "add_before": {
                      "type": "string",
                      "description": "Content to add before found pattern"
                    },
                    "replace": {
                      "type": "string",
                      "description": "Content to replace found pattern with"
                    },
                    "delete": {
                      "type": "boolean",
                      "description": "Set to true to delete found pattern",
                      "const": true
                    }
                  },
                  "oneOf": [
                    {"required": ["add_after"]},
                    {"required": ["add_before"]},
                    {"required": ["replace"]},
                    {"required": ["delete"]}
                  ]
                }
              }
            }
          }
        }
      }
    },
    {
      "description": "MODERN FORMAT - Mixed operations (file_create, file_delete, code_edit)",
      "additionalProperties": false,
      "required": ["plan", "operations"],
      "properties": {
        "plan": {
          "type": "string",
          "description": "Plan name (kebab-case)",
          "minLength": 1
        },
        "operations": {
          "type": "array",
          "description": "Array of operations (max 5 total, max 3 deletions)",
          "minItems": 1,
          "maxItems": 5,
          "items": {
            "oneOf": [
              {
                "description": "CREATE - Create new file with content",
                "type": "object",
                "additionalProperties": false,
                "required": ["type", "path", "content"],
                "properties": {
                  "type": {"const": "file_create"},
                  "path": {"type": "string", "minLength": 1},
                  "content": {"type": "string", "minLength": 1}
                }
              },
              {
                "description": "DELETE - Delete file (max 3 per config)",
                "type": "object",
                "additionalProperties": false,
                "required": ["type", "path", "reason"],
                "properties": {
                  "type": {"const": "file_delete"},
                  "path": {"type": "string", "minLength": 1},
                  "reason": {"type": "string", "minLength": 10}
                }
              },
              {
                "description": "EDIT - Edit existing file code",
                "type": "object",
                "additionalProperties": false,
                "required": ["type", "path", "edits"],
                "properties": {
                  "type": {"const": "code_edit"},
                  "path": {"type": "string", "minLength": 1},
                  "edits": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["find"],
                      "properties": {
                        "find": {"type": "string", "minLength": 1},
                        "add_after": {"type": "string"},
                        "add_before": {"type": "string"},
                        "replace": {"type": "string"},
                        "delete": {"type": "boolean", "const": true}
                      },
                      "oneOf": [
                        {"required": ["add_after"]},
                        {"required": ["add_before"]},
                        {"required": ["replace"]},
                        {"required": ["delete"]}
                      ]
                    }
                  }
                }
              }
            ]
          }
        }
      }
    }
  ]
}
